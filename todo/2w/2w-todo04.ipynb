   "source": [
    "## 문제\n",
    "125초는 몇분 몇초인지 출력하는 프로그램을 작성하세요."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 초 단위 시간\n",
    "total_seconds = 125"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 분과 초로 변환\n",
    "minutes = total_seconds // 60\n",
    "seconds = total_seconds % 60"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 결과 출력\n",
    "print(f\"{total_seconds}초는 {minutes}분 {seconds}초입니다.\")"
   ]
  }
 ],
